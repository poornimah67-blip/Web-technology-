<!DOCTYPE html>
<html>
<head>
    <title>Online Shopping Order Form</title>
</head>
<body>

    <h2>Online Shopping Order Form</h2>

    <form>
        <label>Customer Name:</label><br>
        <input type="text" name="name" required><br><br>

        <label>Email:</label><br>
        <input type="email" name="email" required><br><br>

        <label>Phone Number:</label><br>
        <input type="tel" name="phone" required><br><br>

        <label>Select Product:</label><br>
        <select name="product">
            <option>Mobile</option>
            <option>Laptop</option>
            <option>Headphones</option>
            <option>Watch</option>
        </select><br><br>

        <label>Quantity:</label><br>
        <input type="number" name="quantity" min="1" required><br><br>

        <label>Delivery Address:</label><br>
        <textarea rows="4" cols="30" required></textarea><br><br>

        <label>Payment Method:</label><br>
        <input type="radio" name="payment" required> Cash on Delivery
        <input type="radio" name="payment"> UPI
        <input type="radio" name="payment"> Card<br><br>

        <input type="submit" value="Place Order">
        <input type="reset" value="Clear">

    </form>

</body>
</html>
