<!DOCTYPE html>
<html>
<head>
    <title>Table Example</title>
</head>
<body>

<h2>Student Marks Table</h2>

<table border="1">
    <tr>
        <th>Name</th>
        <th>Subject</th>
        <th>Marks</th>
    </tr>

    <tr>
        <td>Ram</td>
        <td>Maths</td>
        <td>90</td>
    </tr>

    <tr>
        <td>Shyam</td>
        <td>Science</td>
        <td>85</td>
    </tr>

    <tr>
        <td>Ajay</td>
        <td>English</td>
        <td>88</td>
    </tr>

</table>

</body>
</html>
