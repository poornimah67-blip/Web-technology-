<!DOCTYPE html>
<html>
<body>

<h3 id="count">3</h3>

<script>
let num = 3;

let timer = setInterval(function() {
    if (num > 1) {
        num--;
        document.getElementById("count").innerHTML = num;
    } else {
        clearInterval(timer);
        document.getElementById("count").innerHTML = "Happy Birthday Panda 🐼";
    }
}, 1000);
</script>

</body>
</html>
